{
  "mode": "dev",
  "runtime": {
    "requestTimeout": "30s",
    "healthTimeout": "5s",
    "maxPayloadSize": 1048576,
    "maxEventsPerSecond": 50
  },
  "storage": {
    "sqlitePath": "./auxitalk-dev.db"
  },
  "control": {
    "enabled": true,
    "addr": ":8090"
  },
  "plugins": [
    {
      "manifest": "../plugin-openai/plugin.json",
      "enabled": true,
      "env": {
        "OPENAI_BASE_URL": "http://localhost:8317/v1",
        "OPENAI_MODEL": "topmodel",
        "OPENAI_API_KEY": "dev-local-key"
      }
    },
    {
      "manifest": "../plugin-whatsapp/plugin.json",
      "enabled": true,
      "env": {
        "WHATSAPP_DB_PATH": "./whatsapp-dev.db"
      }
    },
    {
      "manifest": "../plugin-dashboard/plugin.json",
      "enabled": false,
      "env": {
        "DASHBOARD_PORT": "8080",
        "AUXITALK_CORE_URL": "http://127.0.0.1:8090"
      }
    }
  ],
  "workflows": [
    {
      "id": "demo-workflow",
      "name": "Demo Workflow",
      "enabled": true,
      "rules": [
        {
          "id": "demo-rule",
          "enabled": true,
          "trigger": {
            "eventType": "message.received",
            "source": "whatsapp"
          },
          "action": {
            "type": "emit_event",
            "risk": "low",
            "payload": {
              "eventType": "demo.workflow.triggered"
            }
          }
        }
      ]
    }
  ]
}
