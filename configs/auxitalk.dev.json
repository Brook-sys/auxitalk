{
  "mode": "dev",
  "runtime": {
    "requestTimeout": "30s",
    "healthTimeout": "5s",
    "maxPayloadSize": 1048576,
    "maxEventsPerSecond": 50,
    "logPath": "./logs/auxitalkd.log"
  },
  "storage": {
    "sqlitePath": "./auxitalk-dev.db"
  },
  "control": {
    "enabled": true,
    "addr": ":8090"
  },
  "plugins": [
    {
      "manifest": "../plugin-openai/plugin.json",
      "enabled": true,
      "env": {
        "OPENAI_BASE_URL": "http://localhost:8317/v1",
        "OPENAI_MODEL": "topmodel",
        "OPENAI_API_KEY": "dev-local-key"
      }
    },
    {
      "manifest": "../plugin-whatsapp/plugin.json",
      "enabled": true,
      "env": {
        "WHATSAPP_DB_PATH": "./whatsapp-dev.db"
      }
    },
    {
      "manifest": "../plugin-telegram/plugin.json",
      "enabled": false,
      "env": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}",
        "TELEGRAM_API_BASE_URL": "https://api.telegram.org",
        "TELEGRAM_POLL_INTERVAL": "2s"
      }
    },
    {
      "manifest": "../plugin-stt/plugin.json",
      "enabled": false,
      "env": {
        "STT_BASE_URL": "https://api.groq.com/openai/v1",
        "STT_MODEL": "whisper-large-v3",
        "STT_API_KEY": "${STT_API_KEY}"
      }
    },
    {
      "manifest": "../plugin-dashboard/plugin.json",
      "enabled": false,
      "env": {
        "DASHBOARD_PORT": "8080",
        "AUXITALK_CORE_URL": "http://127.0.0.1:8090"
      }
    }
  ],
  "workflows": [
    {
      "id": "whatsapp-to-ai",
      "name": "Auto-Reply AI",
      "enabled": true,
      "rules": [
        {
          "id": "ask-ai",
          "enabled": true,
          "trigger": {
            "eventType": "message.received",
            "source": "whatsapp"
          },
          "actions": [
            {
              "type": "openai.ai.complete",
              "risk": "medium",
              "payload": {
                "prompt": "{{payload.text}}",
                "system": "You are a friendly AI assistant responding on WhatsApp. Keep your answers short, using up to 2 sentences. Use emojis."
              }
            }
          ]
        },
        {
          "id": "reply-whatsapp",
          "enabled": true,
          "trigger": {
            "eventType": "action.executed",
            "source": "core.runtime",
            "conditions": [
              {
                "field": "payload.actionType",
                "operator": "==",
                "value": "openai.ai.complete"
              },
              {
                "field": "payload.status",
                "operator": "==",
                "value": "completed"
              }
            ]
          },
          "actions": [
            {
              "type": "whatsapp.message.send",
              "risk": "low",
              "payload": {
                "to": "{{event.sessionId}}",
                "text": "{{payload.result.text}}"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "telegram-audio-to-ai",
      "name": "Telegram Audio to AI",
      "enabled": true,
      "rules": [
        {
          "id": "transcribe-audio",
          "enabled": true,
          "trigger": {
            "eventType": "audio.received",
            "source": "telegram"
          },
          "actions": [
            {
              "type": "stt.stt.transcribe",
              "risk": "low",
              "payload": {
                "audio_url": "{{payload.audio_url}}",
                "language": "pt"
              }
            }
          ]
        },
        {
          "id": "ask-ai-from-audio",
          "enabled": true,
          "trigger": {
            "eventType": "action.executed",
            "source": "core.runtime",
            "conditions": [
              {
                "field": "payload.actionType",
                "operator": "==",
                "value": "stt.stt.transcribe"
              },
              {
                "field": "payload.status",
                "operator": "==",
                "value": "completed"
              }
            ]
          },
          "actions": [
            {
              "type": "openai.ai.complete",
              "risk": "medium",
              "payload": {
                "prompt": "{{payload.result.text}}",
                "system": "You are a friendly AI assistant responding on Telegram. Reply concisely and kindly based on the audio transcription."
              }
            }
          ]
        },
        {
          "id": "reply-telegram",
          "enabled": true,
          "trigger": {
            "eventType": "action.executed",
            "source": "core.runtime",
            "conditions": [
              {
                "field": "payload.actionType",
                "operator": "==",
                "value": "openai.ai.complete"
              },
              {
                "field": "payload.status",
                "operator": "==",
                "value": "completed"
              },
              {
                "field": "session.channel",
                "operator": "==",
                "value": "telegram"
              }
            ]
          },
          "actions": [
            {
              "type": "telegram.message.send",
              "risk": "low",
              "payload": {
                "chatId": "{{event.sessionId}}",
                "text": "{{payload.result.text}}"
              }
            }
          ]
        }
      ]
    }
  ]
}
